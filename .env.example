# Google AI Studio API key for Gemma 4 (primary path).
# Obtain a free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the default Gemma model name.
# Defaults to "gemma-4-31b-it".
ASTRALBRIDGE_GEMMA_MODEL=

# Optional: local Gemma runner command (alternative to GEMINI_API_KEY).
# The command must read a prompt from stdin and write the completion to stdout.
# Example: ASTRALBRIDGE_GEMMA_COMMAND="ollama run gemma3"
# ASTRALBRIDGE_GEMMA_COMMAND=

# Optional: HuggingFace token.
# Required if the AION model download needs authentication.
HF_TOKEN=
